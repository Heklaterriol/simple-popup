<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_SIMPLEPOPUP</name>
    <author>Hekla</author>
    <creationDate>2026-07</creationDate>
    <copyright>Copyright (C) 2026 Hekla. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <version>1.2.0</version>
    <description>MOD_SIMPLEPOPUP_XML_DESCRIPTION</description>
    <namespace path="src">Hekla\Module\Popup</namespace>
    <files>
        <folder module="mod_simplepopup">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
        <file>mod_simplepopup.xml</file>
        <file>README.md</file>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/en-GB.mod_simplepopup.ini</language>
        <language tag="en-GB">language/en-GB/en-GB.mod_simplepopup.sys.ini</language>
        <language tag="de-DE">language/de-DE/de-DE.mod_simplepopup.ini</language>
        <language tag="de-DE">language/de-DE/de-DE.mod_simplepopup.sys.ini</language>
    </languages>
    <media destination="mod_simplepopup" folder="media">
        <folder>css</folder>
        <folder>js</folder>
    </media>
    <config>
        <fields name="params" addfieldprefix="Hekla\Module\Popup\Field">
            <fieldset name="basic" label="MOD_SIMPLEPOPUP_FIELDSET_CONTENT">
                <field
                    name="content"
                    type="editor"
                    label="MOD_SIMPLEPOPUP_FIELD_CONTENT_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_CONTENT_DESC"
                    filter="raw"
                    buttons="true"
                    hiddenLabel="true"
                />
                <field
                    name="link_url"
                    type="url"
                    label="MOD_SIMPLEPOPUP_FIELD_LINK_URL_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_LINK_URL_DESC"
                    filter="url"
                />
                <field
                    name="link_target_blank"
                    type="radio"
                    label="MOD_SIMPLEPOPUP_FIELD_LINK_TARGET_LABEL"
                    class="btn-group btn-group-yesno"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                    showon="link_url!:"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
            <fieldset name="options" label="MOD_SIMPLEPOPUP_FIELDSET_OPTIONS">
                <field
                    name="delay_ms"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_DELAY_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_DELAY_DESC"
                    default="5000"
                    min="0"
                    max="60000"
                    step="100"
                    filter="integer"
                />
                <field
                    name="repeat_mode"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_REPEAT_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_REPEAT_DESC"
                    default="once"
                >
                    <option value="once">MOD_SIMPLEPOPUP_FIELD_REPEAT_ONCE</option>
                    <option value="repeated">MOD_SIMPLEPOPUP_FIELD_REPEAT_REPEATED</option>
                    <option value="cookie">MOD_SIMPLEPOPUP_FIELD_REPEAT_COOKIE</option>
                </field>

                <field
                    name="cookie_hours"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_COOKIE_HOURS_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_COOKIE_HOURS_DESC"
                    default="24"
                    min="1"
                    max="8760"
                    step="1"
                    filter="integer"
                    showon="repeat_mode:cookie"
                />
                <field
                    name="position_vertical"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_POSITION_V_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_POSITION_V_DESC"
                    default="middle"
                >
                    <option value="top">MOD_SIMPLEPOPUP_FIELD_POSITION_TOP</option>
                    <option value="middle">MOD_SIMPLEPOPUP_FIELD_POSITION_MIDDLE</option>
                    <option value="bottom">MOD_SIMPLEPOPUP_FIELD_POSITION_BOTTOM</option>
                </field>
                <field
                    name="position_horizontal"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_POSITION_H_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_POSITION_H_DESC"
                    default="center"
                >
                    <option value="left">MOD_SIMPLEPOPUP_FIELD_POSITION_LEFT</option>
                    <option value="center">MOD_SIMPLEPOPUP_FIELD_POSITION_CENTER</option>
                    <option value="right">MOD_SIMPLEPOPUP_FIELD_POSITION_RIGHT</option>
                </field>
                <field
                    name="overlay_opacity"
                    type="range"
                    label="MOD_SIMPLEPOPUP_FIELD_OVERLAY_OPACITY_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_OVERLAY_OPACITY_DESC"
                    default="55"
                    min="0"
                    max="90"
                    step="5"
                    filter="integer"
                />
                <field
                    name="width_mode"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_WIDTH_MODE_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_WIDTH_MODE_DESC"
                    default="px"
                >
                    <option value="auto">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_AUTO</option>
                    <option value="px">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_PX</option>
                    <option value="percent">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_PERCENT</option>
                    <option value="full">MOD_SIMPLEPOPUP_FIELD_WIDTH_MODE_FULL</option>
                </field>
                <field
                    name="width_px"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_WIDTH_PX_LABEL"
                    default="480"
                    min="100"
                    max="2000"
                    step="10"
                    filter="integer"
                    showon="width_mode:px"
                />
                <field
                    name="width_percent"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_WIDTH_PERCENT_LABEL"
                    default="60"
                    min="1"
                    max="100"
                    step="1"
                    filter="integer"
                    showon="width_mode:percent"
                />
                <field
                    name="height_mode"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_HEIGHT_MODE_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_HEIGHT_MODE_DESC"
                    default="auto"
                >
                    <option value="auto">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_AUTO</option>
                    <option value="px">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_PX</option>
                    <option value="percent">MOD_SIMPLEPOPUP_FIELD_SIZE_MODE_PERCENT</option>
                    <option value="full">MOD_SIMPLEPOPUP_FIELD_HEIGHT_MODE_FULL</option>
                </field>
                <field
                    name="height_px"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_HEIGHT_PX_LABEL"
                    default="400"
                    min="100"
                    max="2000"
                    step="10"
                    filter="integer"
                    showon="height_mode:px"
                />
                <field
                    name="height_percent"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_HEIGHT_PERCENT_LABEL"
                    default="60"
                    min="1"
                    max="100"
                    step="1"
                    filter="integer"
                    showon="height_mode:percent"
                />
                <field name="bg_color" type="color" label="MOD_SIMPLEPOPUP_FIELD_BG_COLOR_LABEL" default="#ffffff" />

                <field
                    name="text_color"
                    type="color"
                    label="MOD_SIMPLEPOPUP_FIELD_TEXT_COLOR_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_TEXT_COLOR_DESC"
                    default="#222222"
                />

                <field
                    name="link_color"
                    type="color"
                    label="MOD_SIMPLEPOPUP_FIELD_LINK_COLOR_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_LINK_COLOR_DESC"
                    default=""
                />
                <field
                    name="border_width"
                    type="number"
                    label="MOD_SIMPLEPOPUP_FIELD_BORDER_WIDTH_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_BORDER_WIDTH_DESC"
                    default="0"
                    min="0"
                    max="20"
                    step="1"
                    filter="integer"
                />
                <field name="border_color" type="color" label="MOD_SIMPLEPOPUP_FIELD_BORDER_COLOR_LABEL" default="#cccccc" />
                <field
                    name="box_shadow"
                    type="list"
                    label="MOD_SIMPLEPOPUP_FIELD_SHADOW_LABEL"
                    description="MOD_SIMPLEPOPUP_FIELD_SHADOW_DESC"
                    default="medium"
                >
                    <option value="none">MOD_SIMPLEPOPUP_FIELD_SHADOW_NONE</option>
                    <option value="soft">MOD_SIMPLEPOPUP_FIELD_SHADOW_SOFT</option>
                    <option value="medium">MOD_SIMPLEPOPUP_FIELD_SHADOW_MEDIUM</option>
                    <option value="strong">MOD_SIMPLEPOPUP_FIELD_SHADOW_STRONG</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>